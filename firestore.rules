rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Menü öğeleri: Herkes okuyabilir, sadece giriş yapmış admin yazabilir
    match /menuItems/{itemId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Kategoriler: Herkes okuyabilir, sadece giriş yapmış admin yazabilir
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
